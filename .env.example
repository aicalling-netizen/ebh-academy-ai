# ── LiveKit ────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_PUBLIC_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=academy-agent
LIVEKIT_FORCE_DISPATCH=true

# ── LLM provider ─────────────────────────────────────────────────────────
LIVEKIT_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ── STT provider ─────────────────────────────────────────────────────────
LIVEKIT_STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=

# ── TTS provider ─────────────────────────────────────────────────────────
LIVEKIT_TTS_PROVIDER=inworld
INWORLD_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Academy config ────────────────────────────────────────────────────────
ACADEMY_NAME=EBH Academy
ACADEMY_PHONE=+971563900330
ACADEMY_EMAIL=support@ebhacademy.com
ACADEMY_WEBSITE=https://ebhacademy.com

# ── Gateway auth ──────────────────────────────────────────────────────────
GATEWAY_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Ultravox realtime stack (Phase 1, parallel to LiveKit) ───────────────
# Get API key from https://app.ultravox.ai/settings
ULTRAVOX_API_KEY=
# Agent UUID from your Ultravox dashboard
ULTRAVOX_AGENT_ID=
# Shared secret used to sign webhook callbacks (any long random string)
ULTRAVOX_TOOL_SECRET=
# Optional overrides
ULTRAVOX_BASE_URL=https://api.ultravox.ai
ULTRAVOX_MAX_DURATION=1800s
ULTRAVOX_AR_INWORLD_VOICE_ID=WcxyRPjVQcpVYmceBQO4Helb
