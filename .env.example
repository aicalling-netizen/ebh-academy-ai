# ── LiveKit ────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_PUBLIC_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=academy-agent
LIVEKIT_FORCE_DISPATCH=true

# ── LLM provider ─────────────────────────────────────────────────────────
LIVEKIT_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ── STT provider ─────────────────────────────────────────────────────────
LIVEKIT_STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=

# ── TTS provider ─────────────────────────────────────────────────────────
LIVEKIT_TTS_PROVIDER=inworld
INWORLD_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Academy config ────────────────────────────────────────────────────────
ACADEMY_NAME=EBH Academy
ACADEMY_PHONE=+971563900330
ACADEMY_EMAIL=support@ebhacademy.com
ACADEMY_WEBSITE=https://ebhacademy.com

# ── Gateway auth ──────────────────────────────────────────────────────────
GATEWAY_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Cascaded stack (English) — Groq LLM + ElevenLabs TTS ─────────────────
# Stack B used when lang=en and stack=cascaded (default for English callers).
# Get a Groq API key at https://console.groq.com/
GROQ_API_KEY=
GROQ_LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Get an ElevenLabs API key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── Anthropic Claude (Arabic / Hindi / Urdu — and ultravox stack) ────────
ANTHROPIC_LLM_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_PROMPT_CACHING=true
